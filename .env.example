# ================================================================
#  Polyarbooor — Polymarket BTC 15min Box Arbitrage Bot
#  https://github.com/RohanKishibeCN/Polyarbooor
# ================================================================

# Polymarket API 凭证（必填）
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here
POLYMARKET_SIGNATURE_TYPE=1
POLYMARKET_FUNDER=0x_your_wallet_address
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# 市场配置（不填则自动发现）
POLYMARKET_MARKET_SLUG=
POLYMARKET_MARKET_ID=
POLYMARKET_YES_TOKEN_ID=
POLYMARKET_NO_TOKEN_ID=

# 策略参数
# 二元市场两边价格之和低于此值时触发（含 spread, 通常>1.0）
TARGET_PAIR_COST=1.01
# 每次交易买入股数。BTC 15min 市场深度有限，5-10 股更易成交
ORDER_SIZE=5
# 每笔交易扣除 gas 后最低净利润（低于此值不交易）
MIN_NET_PROFIT=0.02

# 风控参数
DRY_RUN=true
MAX_TRADES_PER_MARKET=3
MIN_TIME_REMAINING_MINUTES=1
BALANCE_SLACK=0.15
COOLDOWN_SECONDS=5
MAX_IMBALANCE=5
MAX_DAILY_LOSS=50
MAX_CONSECUTIVE_FAILURES=5

# Gas & 网络
EST_GAS_PER_ORDER=0.02
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
HTTP_TIMEOUT=15
API_RETRY_COUNT=3
API_RETRY_DELAY=1.0

# 扫描间隔（秒），2 秒以上避免 API 限流
SCAN_INTERVAL=2
MARKET_SWITCH_DELAY=30

# Notion 集成
NOTION_ENABLED=false
NOTION_API_KEY=
NOTION_DATABASE_ID=

# 日志
VERBOSE=false
LOG_FILE=
HIDE_CREDENTIALS=true
